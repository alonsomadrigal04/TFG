[resource]
script = ExtResource("1_2vjvc")
Name = "Pipa de fumar"
Scene = ExtResource("1_b60y2")
Icon = ExtResource("1_tbpjh")
Description = "Una pipa en forma de lirio, de más allá del mar Nimio. Si es de Fled quizá venga de Venita Estolfeo \"El otro paraíso\". La pipa parece una flor, pero está hecha de madera de brezo."
Comentary = "Esto... Puaj, por su hedor a rumor marrón si que parece una pipa de fumar. Aunque he de admitir que es bonita... ¿Todas las pipas del otro Paraíso serán así?"
