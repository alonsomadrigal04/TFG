[resource]
script = ExtResource("1_2vjvc")
Name = "Pipa de Fumar"
Scene = ExtResource("1_b60y2")
Icon = ExtResource("1_tbpjh")
Description = "Una pipa palidrense, de más allá del mar Fatuo. Por los dibujos que tiene grabados en el lado, es de una ornamentación un poco exagerada; posiblemente se creó con el objetivo de exponerla más que de usarla. Aunque esta apesta a Rumor Marrón bien fuerte. No sabía que Fled fumase tanto."
Comentary = "Una pipa... un tanto curiosa. Por su aspecto, posiblemente sea de Palindra. Creo que es de Fled; dijo que la estaba buscando."
metadata/_custom_type_script = "uid://bjqo5x42b7xkd"
